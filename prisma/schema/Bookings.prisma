model Booking {
  id            String        @id @default(uuid())
  customerId    String
  technicianId  String
  serviceId     String

  scheduledTime DateTime
  status        BookingStatus @default(Requested)
  notes         String?       @db.VarChar(500)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer   Users   @relation("CustomerBookings", fields: [customerId], references: [id])
  technician Users   @relation("TechnicianBookings", fields: [technicianId], references: [id])
  service    Service @relation(fields: [serviceId], references: [id])

  payment Payment?
  review  Review?
}