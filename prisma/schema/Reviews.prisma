model Review {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  customerId   String
  technicianId String
  rating       Int
  comment      String?  @db.VarChar(500)
  createdAt    DateTime @default(now())

  booking    Booking @relation(fields: [bookingId], references: [id])
  customer   Users    @relation("CustomerReviews", fields: [customerId], references: [id])
  technician Users    @relation("TechnicianReviews", fields: [technicianId], references: [id])
}